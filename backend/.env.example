# BrokerFlow Backend - copy to .env and fill values

# ---------------------------------------------------------------------------
# Neon (recommended for hosted PostgreSQL)
# ---------------------------------------------------------------------------
# In Neon Console: Project → Connection details
# 1. Copy "Pooled connection" → DATABASE_URL (host contains -pooler)
# 2. Copy "Direct connection" → DIRECT_URL (host does NOT contain -pooler)
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ---------------------------------------------------------------------------
# Local PostgreSQL (set DIRECT_URL same as DATABASE_URL)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/brokerflow?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/brokerflow?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# CORS: set to your frontend URL so the browser allows API calls (e.g. on Render set this)
# Local: http://localhost:5173  |  Production: https://your-frontend.vercel.app (or Netlify URL)
FRONTEND_URL="http://localhost:5173"

# Optional: API port (default 5000)
PORT=5000
