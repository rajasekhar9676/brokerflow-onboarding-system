# BrokerFlow Backend - copy to .env and fill values

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/brokerflow?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Optional: CORS origin for frontend (defaults to http://localhost:5173)
FRONTEND_URL="http://localhost:5173"

# Optional: API port (default 5000)
PORT=5000
