// BrokerFlow Onboarding System - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  BROKER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(BROKER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  customers Customer[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String
  gstin     String
  brokerId  String
  broker    User     @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brokerId])
}
