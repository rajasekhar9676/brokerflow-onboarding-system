// BrokerFlow Onboarding System - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

// Neon: DATABASE_URL = pooled (ends in -pooler), DIRECT_URL = direct (no -pooler)
// Local Postgres: set DIRECT_URL to the same value as DATABASE_URL
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  BROKER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(BROKER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  customers Customer[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String
  gstin     String
  brokerId  String
  broker    User     @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brokerId])
}
